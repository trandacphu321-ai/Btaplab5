<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Danh sách sản phẩm</title>
    <style>
        /* Một chút CSS cơ bản cho dễ nhìn */
        body { font-family: Arial, sans-serif; margin: 0; padding: 20px; }
        .header { display: flex; justify-content: space-between; align-items: center; background: #f4f4f4; padding: 10px 20px; margin-bottom: 20px; }
        .product-list { display: flex; gap: 20px; flex-wrap: wrap; }
        .product-card { border: 1px solid #ccc; padding: 15px; width: 220px; text-align: center; border-radius: 8px; }
        .product-card img { max-width: 100%; height: 150px; object-fit: cover; }
        .btn { padding: 8px 12px; background: #007bff; color: white; text-decoration: none; border: none; border-radius: 4px; cursor: pointer; }
        .btn:hover { background: #0056b3; }
    </style>
</head>
<body>

    <div class="header">
        <h2>Cửa Hàng Điện Tử</h2>
        <h3><a href="/cart" style="text-decoration: none; color: #ff5722;">🛒 Giỏ hàng (<%= cartCount %>)</a></h3>
    </div>

    <h1>Tất Cả Sản Phẩm</h1>
    
    <div class="product-list">
        <% products.forEach(function(product) { %>
            <div class="product-card">
                <img src="<%= product.imageUrl %>" alt="<%= product.name %>">
                <h3><%= product.name %></h3>
                <p>Giá: <%= product.price.toLocaleString() %> VNĐ</p>
                
                <a href="/product/<%= product._id %>" class="btn" style="background: #28a745;">Xem chi tiết</a>
                
                <form action="/cart/add/<%= product._id %>" method="POST" style="margin-top: 10px;">
                    <button type="submit" class="btn">Thêm vào giỏ</button>
                </form>
            </div>
        <% }); %>
    </div>

</body>
</html>