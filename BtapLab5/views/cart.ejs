<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Giỏ hàng của bạn</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 0; padding: 20px; }
        .header { display: flex; justify-content: space-between; align-items: center; background: #f4f4f4; padding: 10px 20px; margin-bottom: 20px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { padding: 15px; text-align: left; border-bottom: 1px solid #ddd; }
        th { background-color: #f8f9fa; }
        .cart-img { width: 80px; height: 80px; object-fit: cover; border-radius: 4px; }
        .btn { padding: 10px 15px; background: #28a745; color: white; text-decoration: none; border: none; border-radius: 4px; cursor: pointer; }
        .btn:hover { background: #218838; }
        .btn-back { background: #6c757d; }
        .btn-back:hover { background: #5a6268; }
        .total-row { font-size: 20px; font-weight: bold; text-align: right; padding-top: 20px; }
    </style>
</head>
<body>

    <div class="header">
        <h2>Cửa Hàng Điện Tử</h2>
        <h3><a href="/" style="text-decoration: none; color: #333;">🏠 Trang chủ</a></h3>
    </div>

    <h1>🛒 Giỏ hàng của bạn</h1>

    <% if (cart.length === 0) { %>
        <p style="font-size: 18px; color: #555;">Giỏ hàng đang trống.</p>
        <br>
        <a href="/" class="btn btn-back">⬅ Tiếp tục mua sắm</a>
    <% } else { %>
        <table>
            <thead>
                <tr>
                    <th>Hình ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Đơn giá</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                <% cart.forEach(function(item) { %>
                    <tr>
                        <td><img src="<%= item.product.imageUrl %>" alt="<%= item.product.name %>" class="cart-img"></td>
                        <td><strong><%= item.product.name %></strong></td>
                        <td><%= item.product.price.toLocaleString() %> VNĐ</td>
                        <td><%= item.quantity %></td>
                        <td style="color: #e44d26; font-weight: bold;">
                            <%= (item.product.price * item.quantity).toLocaleString() %> VNĐ
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>

        <div class="total-row">
            Tổng cộng: <span style="color: #e44d26; font-size: 24px;"><%= totalAmount.toLocaleString() %> VNĐ</span>
        </div>

        <div style="margin-top: 30px;">
            <a href="/" class="btn btn-back">⬅ Tiếp tục mua sắm</a>
            <button class="btn" style="float: right;">Thanh toán ngay</button>
        </div>
    <% } %>

</body>
</html>